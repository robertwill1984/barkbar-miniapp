.home-page {
  padding-top: 24rpx;
  padding-bottom: 156rpx;
}

.home-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.home-brand {
  display: block;
  color: #20231f;
  font-size: 42rpx;
  font-weight: 860;
  line-height: 52rpx;
  letter-spacing: -0.4rpx;
}

.home-brand-sub {
  display: block;
  margin-top: 6rpx;
  color: #5b6158;
  font-size: 23rpx;
  line-height: 32rpx;
}

.home-member-chip {
  flex: 0 0 auto;
  min-width: 92rpx;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(201, 162, 74, 0.18);
  color: #7a5a00;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 48rpx;
  text-align: center;
  box-sizing: border-box;
}

.home-hero {
  min-height: 376rpx;
  padding: 42rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  border-radius: 36rpx;
  background:
    linear-gradient(135deg, rgba(63, 111, 78, 0.90), rgba(78, 166, 200, 0.74)),
    radial-gradient(circle at 86% 16%, rgba(201, 162, 74, 0.54), transparent 34%);
  box-shadow: 0 20rpx 56rpx rgba(32, 35, 31, 0.10);
  overflow: hidden;
}

.home-hero-slogan {
  display: block;
  max-width: 470rpx;
  color: #ffffff;
  font-size: 54rpx;
  font-weight: 860;
  line-height: 66rpx;
  letter-spacing: -0.8rpx;
}

.home-hero-subtitle {
  max-width: 500rpx;
  margin-top: 22rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 28rpx;
  line-height: 44rpx;
}

.home-hero-badge {
  position: absolute;
  right: 34rpx;
  bottom: 34rpx;
  height: 52rpx;
  padding: 0 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.34);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 52rpx;
  box-sizing: border-box;
}

.home-business-card,
.home-price-card,
.home-notice-card {
  border: 2rpx solid rgba(216, 210, 196, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 34rpx rgba(32, 35, 31, 0.06);
}

.home-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.home-section-title {
  margin-bottom: 0;
  font-size: 34rpx;
  line-height: 46rpx;
}

.home-status-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(63, 111, 78, 0.12);
  color: #3f6f4e;
  font-size: 22rpx;
  font-weight: 760;
  line-height: 30rpx;
}

.home-business-time {
  margin-top: 14rpx;
  color: #5b6158;
}

.home-primary-button {
  height: 96rpx;
  border-radius: 16rpx;
  background: #3f6f4e;
  font-size: 30rpx;
}

.home-block-title {
  display: block;
  margin: 34rpx 0 18rpx;
  color: #20231f;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.home-feature-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 0;
}

.home-feature-card {
  min-height: 172rpx;
  padding: 24rpx 20rpx;
  border: 2rpx solid #d8d2c4;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(32, 35, 31, 0.045);
}

.home-feature-icon {
  width: 42rpx;
  height: 42rpx;
  margin-bottom: 12rpx;
  border: 3rpx solid #3f6f4e;
  border-radius: 14rpx;
  box-sizing: border-box;
  position: relative;
  opacity: 0.88;
}

.home-feature-icon-water {
  border-color: #4ea6c8;
}

.home-feature-icon-grass {
  border-color: #3f6f4e;
}

.home-feature-icon-drink {
  border-color: #9a642b;
}

.home-icon-line {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: currentColor;
  opacity: 0.72;
}

.home-icon-line:first-child {
  top: 13rpx;
}

.home-icon-line:last-child {
  top: 24rpx;
}

.home-feature-title {
  font-size: 28rpx;
  line-height: 36rpx;
}

.home-feature-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 32rpx;
}

.home-price-card {
  padding: 30rpx 30rpx 28rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 243, 234, 0.94)),
    radial-gradient(circle at 88% 10%, rgba(201, 162, 74, 0.18), transparent 34%);
}

.home-price-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.home-price-label {
  display: block;
  color: #5b6158;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.home-price-row {
  display: flex;
  align-items: baseline;
  flex: 0 0 auto;
  margin-top: -6rpx;
}

.home-price-symbol {
  color: #3f6f4e;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 42rpx;
}

.home-price-main {
  color: #3f6f4e;
  font-size: 76rpx;
  font-weight: 860;
  line-height: 82rpx;
  letter-spacing: -2rpx;
}

.home-price-desc {
  display: block;
  margin-top: 10rpx;
  color: #20231f;
  font-size: 30rpx;
  font-weight: 760;
  line-height: 42rpx;
}

.home-price-extra {
  display: block;
  margin-top: 14rpx;
  color: #8a6a2a;
  font-size: 24rpx;
  line-height: 34rpx;
}

.home-activity-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 24rpx;
  padding: 26rpx;
  border: 2rpx solid #d8d2c4;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(32, 35, 31, 0.055);
  box-sizing: border-box;
}

.home-activity-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 76rpx;
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  background: rgba(78, 166, 200, 0.16);
  color: #27627a;
  font-size: 30rpx;
  font-weight: 900;
}

.home-activity-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.home-activity-title {
  color: #20231f;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.home-activity-subtitle {
  margin-top: 4rpx;
  color: #8a8e86;
  font-size: 23rpx;
  line-height: 34rpx;
}

.home-notice-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #ece6da;
}

.home-notice-item:last-of-type {
  border-bottom: 0;
}

.home-notice-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 17rpx;
  border-radius: 50%;
  background: #3f6f4e;
  flex: 0 0 auto;
}

.home-notice-text {
  color: #4a4f46;
  font-size: 26rpx;
  line-height: 42rpx;
}

.home-secondary-button {
  height: 88rpx;
  border: 2rpx solid #d8d2c4;
  border-radius: 16rpx;
  background: #ffffff;
  color: #20231f;
}
