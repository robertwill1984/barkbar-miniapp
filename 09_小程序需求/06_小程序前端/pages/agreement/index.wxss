.risk-card {
  margin-top: 24rpx;
  padding: 34rpx 30rpx;
  border-radius: 28rpx;
  background: #20231f;
  color: #ffffff;
  box-shadow: 0 16rpx 44rpx rgba(32, 35, 31, 0.15);
  box-sizing: border-box;
}

.risk-kicker {
  display: block;
  color: #c9a24a;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 32rpx;
  letter-spacing: 4rpx;
}

.risk-title {
  display: block;
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 820;
  line-height: 52rpx;
}

.risk-desc {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
  line-height: 42rpx;
}

.risk-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 22rpx;
}

.risk-mini-card {
  padding: 24rpx;
  border: 2rpx solid rgba(181, 72, 61, 0.26);
  border-radius: 22rpx;
  background: rgba(181, 72, 61, 0.08);
  box-sizing: border-box;
}

.risk-mini-title {
  display: block;
  color: #b5483d;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.risk-mini-desc {
  display: block;
  margin-top: 8rpx;
  color: #4a4f46;
  font-size: 25rpx;
  line-height: 40rpx;
}
