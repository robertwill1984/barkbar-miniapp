.reservation-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(31, 39, 35, 0.08);
}

.reservation-item:last-child {
  border-bottom: 0;
}

.reservation-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.reservation-time {
  color: #1f2723;
  font-size: 30rpx;
  font-weight: 700;
}

.reservation-status {
  flex-shrink: 0;
  color: #3f6f4e;
  font-size: 24rpx;
  font-weight: 700;
}

.reservation-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 10rpx;
}

.mini-button {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 8rpx;
  background: #edf6f2;
  color: #3f6f4e;
  font-size: 24rpx;
}

.mini-button.danger {
  background: #fff0ec;
  color: #b2533e;
}

.checkin-code-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #f7f3ea;
  text-align: center;
}

.checkin-code {
  display: block;
  margin: 12rpx 0;
  color: #1f2723;
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: 0;
}
