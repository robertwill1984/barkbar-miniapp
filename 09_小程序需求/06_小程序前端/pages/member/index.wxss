.member-buy-section {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 12rpx 34rpx rgba(31, 39, 35, 0.08);
}

.member-product {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(31, 39, 35, 0.08);
}

.member-product:last-child {
  border-bottom: 0;
}

.member-product-main {
  flex: 1;
  min-width: 0;
}

.member-product-title {
  display: block;
  color: #1f2723;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.member-product-desc {
  display: block;
  margin-top: 6rpx;
  color: rgba(31, 39, 35, 0.62);
  font-size: 24rpx;
  line-height: 34rpx;
}

.member-product-action {
  width: 150rpx;
  flex-shrink: 0;
  text-align: right;
}

.member-product-price {
  display: block;
  color: #c9a24a;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.member-buy-button {
  width: 132rpx;
  height: 58rpx;
  margin: 10rpx 0 0 auto;
  line-height: 58rpx;
  border-radius: 8rpx;
  background: #3f6f4e;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.member-card {
  margin-top: 28rpx;
  min-height: 260rpx;
  padding: 40rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #20231f, #3f6f4e);
  color: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(32, 35, 31, 0.16);
  box-sizing: border-box;
}

.member-title {
  display: block;
  color: #c9a24a;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 36rpx;
  letter-spacing: 3rpx;
}

.member-desc {
  display: block;
  margin: 12rpx 0 24rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
  line-height: 40rpx;
}

.member-code-button {
  width: 180rpx;
  height: 60rpx;
  margin: 24rpx 0 0;
  line-height: 60rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #3f6f4e;
  font-size: 24rpx;
  font-weight: 700;
}

.member-code-card {
  margin-top: 28rpx;
  padding: 34rpx 28rpx;
  border: 2rpx solid rgba(63, 111, 78, 0.18);
  border-radius: 8rpx;
  background: #f7fbf8;
  text-align: center;
  box-sizing: border-box;
}

.member-code-title {
  display: block;
  color: #3f6f4e;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.member-code {
  display: block;
  margin-top: 10rpx;
  color: #1f2723;
  font-size: 56rpx;
  font-weight: 800;
  line-height: 68rpx;
  letter-spacing: 0;
}

.member-code-desc {
  display: block;
  margin-top: 8rpx;
  color: rgba(31, 39, 35, 0.62);
  font-size: 24rpx;
  line-height: 34rpx;
}

.member-order-section {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 12rpx 34rpx rgba(31, 39, 35, 0.08);
}

.member-order {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(31, 39, 35, 0.08);
}

.member-order:last-child {
  border-bottom: 0;
}

.member-order-main {
  flex: 1;
  min-width: 0;
}

.member-order-title {
  display: block;
  color: #1f2723;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.member-order-time {
  display: block;
  margin-top: 4rpx;
  color: rgba(31, 39, 35, 0.52);
  font-size: 22rpx;
  line-height: 32rpx;
}

.member-order-side {
  width: 152rpx;
  flex-shrink: 0;
  text-align: right;
}

.member-order-amount {
  display: block;
  color: #c9a24a;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.member-order-status {
  display: block;
  margin-top: 4rpx;
  color: #3f6f4e;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 30rpx;
}

.member-order-refund {
  display: block;
  margin-top: 4rpx;
  color: #a6632b;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 30rpx;
}

.member-refund-button {
  width: 144rpx;
  height: 52rpx;
  margin: 10rpx 0 0 auto;
  padding: 0;
  line-height: 52rpx;
  border: 1rpx solid rgba(166, 99, 43, 0.32);
  border-radius: 8rpx;
  background: #fff8ef;
  color: #a6632b;
  font-size: 22rpx;
  font-weight: 700;
}

.member-refund-refresh-button {
  width: 144rpx;
  height: 48rpx;
  margin: 8rpx 0 0 auto;
  padding: 0;
  line-height: 48rpx;
  border: 1rpx solid rgba(63, 111, 78, 0.28);
  border-radius: 8rpx;
  background: #f6fbf6;
  color: #3f6f4e;
  font-size: 22rpx;
  font-weight: 700;
}
