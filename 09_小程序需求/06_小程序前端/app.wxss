page {
  background: #f7f3ea;
  color: #20231f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.45;
}

button {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  border-radius: 0;
  line-height: normal;
}

button::after {
  border: 0;
}

.bb-page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.bb-hero {
  background:
    linear-gradient(135deg, rgba(63, 111, 78, 0.92), rgba(78, 166, 200, 0.78)),
    radial-gradient(circle at 86% 18%, rgba(201, 162, 74, 0.52), transparent 36%);
  border-radius: 36rpx;
  color: #ffffff;
  min-height: 276rpx;
  padding: 44rpx;
  box-shadow: 0 20rpx 56rpx rgba(32, 35, 31, 0.10);
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
}

.bb-hero-mark {
  position: absolute;
  top: 28rpx;
  right: 30rpx;
  width: 116rpx;
  height: 96rpx;
  padding: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 26rpx;
  background: rgba(247, 243, 234, 0.88);
  box-shadow: 0 12rpx 32rpx rgba(32, 35, 31, 0.12);
  box-sizing: border-box;
  opacity: 0.96;
}

.bb-hero-title {
  display: block;
  max-width: 470rpx;
  font-size: 56rpx;
  font-weight: 800;
  line-height: 68rpx;
  letter-spacing: -1rpx;
}

.bb-hero-subtitle {
  display: block;
  max-width: 520rpx;
  margin-top: 20rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 28rpx;
  line-height: 44rpx;
}

.bb-card {
  margin-top: 24rpx;
  padding: 28rpx;
  background: #ffffff;
  border: 2rpx solid #d8d2c4;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(32, 35, 31, 0.055);
  box-sizing: border-box;
}

.bb-card-soft {
  background: #fbf8f0;
}

.bb-section-title {
  display: block;
  margin-bottom: 16rpx;
  color: #20231f;
  font-size: 36rpx;
  font-weight: 750;
  line-height: 52rpx;
}

.bb-body {
  display: block;
  color: #4a4f46;
  font-size: 28rpx;
  line-height: 44rpx;
}

.bb-muted {
  display: block;
  color: #8a8e86;
  font-size: 24rpx;
  line-height: 36rpx;
}

.bb-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
  flex-wrap: wrap;
}

.bb-grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 24rpx;
}

.bb-feature-card {
  min-height: 172rpx;
  padding: 24rpx 20rpx;
  background: #ffffff;
  border: 2rpx solid #d8d2c4;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(32, 35, 31, 0.045);
  box-sizing: border-box;
}

.bb-feature-title {
  display: block;
  color: #20231f;
  font-size: 28rpx;
  font-weight: 760;
  line-height: 36rpx;
}

.bb-feature-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #8a8e86;
  font-size: 22rpx;
  line-height: 32rpx;
}

.bb-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 32rpx;
  box-sizing: border-box;
}

.bb-chip-blue {
  background: rgba(78, 166, 200, 0.18);
  color: #27627a;
}

.bb-chip-gold {
  background: rgba(201, 162, 74, 0.2);
  color: #6d5420;
}

.bb-chip-green {
  background: rgba(167, 215, 184, 0.35);
  color: #2f6441;
}

.bb-button-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 28rpx;
  height: 96rpx;
  line-height: normal;
  border-radius: 16rpx;
  background: #3f6f4e;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 750;
  text-align: center;
}

.bb-button-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  height: 88rpx;
  line-height: normal;
  border: 2rpx solid #d8d2c4;
  border-radius: 16rpx;
  background: #f7f3ea;
  color: #20231f;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.bb-list-item {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 22rpx 0;
  border-bottom: 2rpx solid #ece6da;
  box-sizing: border-box;
}

.bb-list-item:last-child {
  border-bottom: 0;
}

.bb-price {
  display: block;
  color: #3f6f4e;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 56rpx;
}

.bb-warning {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: rgba(78, 166, 200, 0.13);
  border: 2rpx solid rgba(78, 166, 200, 0.34);
  color: #255f74;
  font-size: 26rpx;
  line-height: 40rpx;
  box-sizing: border-box;
}
