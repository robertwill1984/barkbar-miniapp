{
  "name": "barkbar-miniapp-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Bark & Bar 微信小程序后端 MVP-A：登录、宠物档案、协议签署、预约入园。",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "migration:note": "echo \"Run database/migrations/001_schema_v1.1.sql on PostgreSQL test database after backup.\""
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.0",
    "@types/node": "^20.14.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.0"
  }
}
